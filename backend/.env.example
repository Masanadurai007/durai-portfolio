# ── Database (PostgreSQL) ────────────────────────────────────
# Local example: postgresql+asyncpg://postgres:yourpassword@localhost:5432/durai_portfolio
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/durai_portfolio

# Sync URL used only by Alembic migrations (same DB, psycopg2 driver)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/durai_portfolio

# ── AI / Chatbot (free tier) ─────────────────────────────────
# Get a free key at https://console.groq.com/keys — no credit card needed
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email notifications (optional) ───────────────────────────
# Leave blank to skip emailing; submissions are still saved to the database
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=mmasanadurai007@gmail.com

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_NUMBER=919361977522
